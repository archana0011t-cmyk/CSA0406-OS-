#include <stdio.h>
#include <fcntl.h>
#include <unistd.h>
int main()
{
    int fd;
    char buffer[100];
    int n;
    fd = open("student.txt", O_RDONLY);
    if (fd == -1)
    {
        printf("Unable to open file.\n");
        return 1;
    }
    n = read(fd, buffer, sizeof(buffer)-1);
    buffer[n] = '\0';
    printf("File Contents:\n%s", buffer);
    close(fd);
    return 0;
}
