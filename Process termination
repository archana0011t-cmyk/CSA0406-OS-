#include <stdio.h>
#include <stdlib.h>
#include <unistd.h>
#include <sys/wait.h>
int main()
{
    pid_t pid = fork();

    if (pid == 0)
    {
        printf("Child Process is running.\n");
        printf("Child PID: %d\n", getpid());

        printf("Child Process Terminated.\n");
        exit(0);
    }
    else if (pid > 0)
    {
        wait(NULL);   // Parent waits for child
        printf("Parent Process: Child completed successfully.\n");
    }
    else
    {
        printf("Fork Failed!\n");
    }
    return 0;
}
