#include <stdio.h>

int main() {
    int n, i;
    int bt[10], wt[10];
    float avg = 0;

    printf("Enter the number of processes: ");
    scanf("%d", &n);

    // Input Burst Times
    printf("Enter Burst Time for each process:\n");
    for(i = 0; i < n; i++) {
        printf("P%d: ", i + 1);
        scanf("%d", &bt[i]);
    }

    // Calculate Waiting Time
    wt[0] = 0;
    for(i = 1; i < n; i++) {
        wt[i] = wt[i - 1] + bt[i - 1];
    }

    // Display Waiting Time
    printf("\nProcess\tBurst Time\tWaiting Time\n");
    for(i = 0; i < n; i++) {
        printf("P%d\t%d\t\t%d\n", i + 1, bt[i], wt[i]);
        avg += wt[i];
    }

    // Calculate Average Waiting Time
    avg = avg / n;
    printf("\nAverage Waiting Time = %.2f\n", avg);

    return 0;
}
