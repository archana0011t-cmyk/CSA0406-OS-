#include <stdio.h>

#define MAX 5

int queue[MAX];
int front = -1, rear = -1;

// Insert a process into the ready queue
void enqueue(int process) {
    if (rear == MAX - 1) {
        printf("Ready Queue is Full!\n");
    } else {
        if (front == -1)
            front = 0;
        queue[++rear] = process;
        printf("Process %d added to Ready Queue.\n", process);
    }
}

// Remove a process from the ready queue
void dequeue() {
    if (front == -1 || front > rear) {
        printf("Ready Queue is Empty!\n");
    } else {
        printf("Process %d executed and removed from Ready Queue.\n", queue[front]);
        front++;
    }
}

// Display the ready queue
void display() {
    if (front == -1 || front > rear) {
        printf("Ready Queue is Empty!\n");
    } else {
        printf("Ready Queue: ");
        for (int i = front; i <= rear; i++) {
            printf("P%d ", queue[i]);
        }
        printf("\n");
    }
}

int main() {
    int choice, process;

    while (1) {
        printf("\n--- Ready Queue Simulation ---\n");
        printf("1. Add Process\n");
        printf("2. Execute Process\n");
        printf("3. Display Ready Queue\n");
        printf("4. Exit\n");
        printf("Enter your choice: ");
        scanf("%d", &choice);

        switch (choice) {
            case 1:
                printf("Enter Process ID: ");
                scanf("%d", &process);
                enqueue(process);
                break;

            case 2:
                dequeue();
                break;

            case 3:
                display();
                break;

            case 4:
                return 0;

            default:
                printf("Invalid Choice!\n");
        }
    }

    return 0;
}
