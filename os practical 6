#include <stdio.h>

int main() {
    int frames, pages, i, j, k = 0, pageFaults = 0;
    int frame[10], page[30], found;

    printf("Enter number of frames: ");
    scanf("%d", &frames);

    printf("Enter number of pages: ");
    scanf("%d", &pages);

    printf("Enter page reference string:\n");
    for (i = 0; i < pages; i++) {
        scanf("%d", &page[i]);
    }

    // Initialize frames
    for (i = 0; i < frames; i++) {
        frame[i] = -1;
    }

    printf("\nPage Replacement Process:\n");

    for (i = 0; i < pages; i++) {
        found = 0;

        // Check if page is already in frame
        for (j = 0; j < frames; j++) {
            if (frame[j] == page[i]) {
                found = 1;
                break;
            }
        }

        // Page Fault
        if (!found) {
            frame[k] = page[i];
            k = (k + 1) % frames;
            pageFaults++;
        }

        printf("Page %d -> ", page[i]);
        for (j = 0; j < frames; j++) {
            if (frame[j] == -1)
                printf("- ");
            else
                printf("%d ", frame[j]);
        }
        printf("\n");
    }

    printf("\nTotal Page Faults = %d\n", pageFaults);

    return 0;
}
