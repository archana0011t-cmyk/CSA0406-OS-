#include <stdio.h>

int main() {
    int n, i;
    int process[10];

    printf("Enter the number of processes: ");
    scanf("%d", &n);

    // Input process IDs
    for(i = 0; i < n; i++) {
        printf("Enter Process ID %d: ", i + 1);
        scanf("%d", &process[i]);
    }

    printf("\nScheduler Execution Order:\n");

    // Execute processes one by one
    for(i = 0; i < n; i++) {
        printf("Executing Process P%d...\n", process[i]);
    }

    printf("\nAll processes executed successfully.\n");

    return 0;
}
