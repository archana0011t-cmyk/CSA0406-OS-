#include <stdio.h>
#include <fcntl.h>
#include <unistd.h>
int main()
{
    int source, dest;
    char ch;
    source = open("source.txt", O_RDONLY);
    dest = open("destination.txt", O_WRONLY | O_CREAT | O_TRUNC, 0644);
    while(read(source, &ch, 1) > 0)
    {
        write(dest, &ch, 1);
    }
    close(source);
    close(dest);
    Printf("File copied successfully.\n");
    return 0;
}
