#include <stdio.h>
#include <unistd.h>
#include <string.h>
int main()
{
    int p1[2], p2[2];
    char parentMsg[] = "Hello Child";
    char childMsg[] = "Hello Parent";
    char buffer[100];
    pipe(p1);
    pipe(p2);
    if(fork() == 0)
    {
        close(p1[1]);
        read(p1[0], buffer, sizeof(buffer));
        printf("Child received: %s\n", buffer);

        close(p2[0]);
        write(p2[1], childMsg, strlen(childMsg)+1);
    }
    else
    {
        close(p1[0]);
        write(p1[1], parentMsg, strlen(parentMsg)+1);

        close(p2[1]);
        read(p2[0], buffer, sizeof(buffer));
        printf("Parent received: %s\n", buffer);
    }
    return 0;
}
