#include <stdio.h>
#include <fcntl.h>
#include <unistd.h>
#include <string.h>
int main()
{
    int fd;
    char name[50];
    printf("Enter Student Name: ");
    fgets(name, sizeof(name), stdin);
    fd = open("student.txt", O_WRONLY | O_CREAT | O_TRUNC, 0644);
    if (fd == -1)
    {
        printf("Unable to open file.\n");
        return 1;
    }
    write(fd, name, strlen(name));
    printf("Data written successfully.\n");
    close(fd);
    return 0;
}
