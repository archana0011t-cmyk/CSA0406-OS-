#include <stdio.h>
#include <unistd.h>
#include <sys/wait.h>
int main()
{
    int i;

    for (i = 1; i <= 3; i++)
    {
        pid_t pid = fork();

        if (pid == 0)
        {
            printf("Child %d\n", i);
            printf("PID  : %d\n", getpid());
            printf("PPID : %d\n\n", getppid());
            return 0;
        }
    }
    // Parent waits for all children
    for (i = 1; i <= 3; i++)
        wait(NULL);

    printf("Parent Process Completed.\n");
    return 0;
}
